# TTS 引擎：edge-tts / aliyun-tts / mimo-tts / f5-tts
TTS_ENGINE=edge-tts

# 阿里云 Qwen-TTS / Qwen-ASR
DASHSCOPE_API_KEY=
ALIYUN_ASR_MODEL=qwen3-asr-flash
ASR_ENGINE=wav2vec2
ALIYUN_TTS_MODEL=qwen3-tts-instruct-flash
ALIYUN_TTS_VOICE=Neil
ALIYUN_TTS_LANGUAGE_TYPE=Chinese
ALIYUN_TTS_STYLE_PROMPT=请用普通话水平测试示范朗读的风格合成。要求字音准确，声调清楚，语速中等偏稳，语调平实端正，停顿自然，避免俏皮、撒娇、夸张表演和明显情绪化表达。

# 小米 MiMo-V2.5-TTS，接口兼容 OpenAI SDK
MIMO_API_KEY=
MIMO_TTS_MODEL=mimo-v2.5-tts
MIMO_TTS_VOICE=白桦
MIMO_TTS_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_TTS_STYLE_PROMPT=请用普通话水平测试示范朗读的风格合成。要求字音准确，声调清楚，语速中等偏稳，语调平实端正，停顿自然，避免俏皮、撒娇、夸张表演和明显情绪化表达。
